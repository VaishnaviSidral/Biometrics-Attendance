# Database Configuration
# Copy this file to .env and adjust settings as needed

# --- MySQL Configuration (Default) ---
# Create database: CREATE DATABASE attendance_db;
# Create user: CREATE USER 'attendance_user'@'localhost' IDENTIFIED BY 'attendance_pass';
# Grant permissions: GRANT ALL PRIVILEGES ON attendance_db.* TO 'attendance_user'@'localhost';
DATABASE_URL="mysql+pymysql://attendance_user:attendance_pass@localhost:3306/attendance_db"

# --- SQLite Configuration (Alternative) ---
# Uncomment the line below and comment out the MySQL line to use SQLite
# DATABASE_URL="sqlite:///./attendance.db"

# --- Authentication Settings ---
SECRET_KEY="your-secret-key-change-in-production-biometrics-2024"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Default Admin Credentials ---
DEFAULT_ADMIN_USERNAME="admin"
DEFAULT_ADMIN_PASSWORD="admin123"
DEFAULT_EMPLOYEE_PASSWORD="employee123"

# --- Work Policy Configuration ---
EXPECTED_HOURS_PER_DAY=8
WFO_DAYS_PER_WEEK=3
WFH_DAYS_PER_WEEK=2
THRESHOLD_RED=70
THRESHOLD_AMBER=90
