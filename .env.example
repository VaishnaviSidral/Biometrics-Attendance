# ╔══════════════════════════════════════════════════════════╗
# ║  Biometrics Attendance System — Environment Variables   ║
# ║  Copy this file to .env and fill in your actual values  ║
# ╚══════════════════════════════════════════════════════════╝

# ── Biometric Database (READ/WRITE — main application DB) ──
DB_HOST=your_mysql_host
DB_PORT=3306
DB_NAME=biometric_attendance
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# ── Redmine Database (READ ONLY — user validation) ─────────
REDMINE_DB_HOST=your_redmine_db_host
REDMINE_DB_PORT=3306
REDMINE_DB_NAME=redmine
REDMINE_DB_USER=your_redmine_db_user
REDMINE_DB_PASSWORD=your_redmine_db_password

# ── Google OAuth ────────────────────────────────────────────
GOOGLE_ENABLED=true
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ── JWT / Auth ──────────────────────────────────────────────
SECRET_KEY=your_strong_random_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── App Config (defaults shown — override if needed) ───────
# EXPECTED_HOURS_PER_DAY=9
# WFO_DAYS_PER_WEEK=5
# HYBRID_DAYS_PER_WEEK=3
# THRESHOLD_RED=60
# THRESHOLD_AMBER=90
# COMPLIANCE_HOURS=9
# MID_COMPLIANCE_HOURS=7
# NON_COMPLIANCE_HOURS=6
# API_PREFIX=/api
# DEBUG=false

# ── Docker Compose ──────────────────────────────────────────
# Port on which the app will be accessible (default: 8080)
# APP_PORT=8080
